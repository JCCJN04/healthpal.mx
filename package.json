{
  "name": "healthpal-mx",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky",
    "schema:sync": "node scripts/sync-supabase-schema.mjs",
    "schema:sync:verbose": "node scripts/sync-supabase-schema.mjs",
    "privacy:verify": "node scripts/verify-privacy-controls.mjs",
    "privacy:backfill": "node scripts/run-encryption-backfill.mjs",
    "privacy:backfill:dry": "node scripts/run-encryption-backfill.mjs --dry-run",
    "privacy:backfill:legacy": "node scripts/run-encryption-backfill.mjs --allow-legacy-service-key",
    "privacy:backfill:dry:legacy": "node scripts/run-encryption-backfill.mjs --dry-run --allow-legacy-service-key",
    "privacy:backfill:cli": "node scripts/run-encryption-backfill-cli.mjs",
    "privacy:backfill:cli:dry": "node scripts/run-encryption-backfill-cli.mjs --dry-run",
    "privacy:backfill:enqueue": "node scripts/backfill-admin.mjs enqueue",
    "privacy:backfill:stats": "node scripts/backfill-admin.mjs stats",
    "privacy:backfill:coverage": "node scripts/verify-backfill-coverage.mjs",
    "privacy:phase4:readiness": "node scripts/verify-phase4-readiness.mjs",
    "demo:doctor:setup": "node scripts/create-demo-doctor.mjs",
    "test": "node --experimental-strip-types --test src/**/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.94.5",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "date-fns": "^4.1.0",
    "dwv": "^0.36.2",
    "lenis": "^1.3.23",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.12.0",
    "mapbox-gl": "^3.19.0",
    "motion": "^12.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.21.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/mapbox__point-geometry": "^1.0.87",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pg": "^8.19.0",
    "postcss": "^8.4.33",
    "semantic-release": "^24.0.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md}": []
  }
}
